---
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  activePage?: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  activePage,
  description = "I write songs to remind us of our brilliance. I teach people how to mine their own life for truth, beauty, and messy expression. I take your \"writer's block\" excuse personally.",
  ogImage = "/images/hero-main.png"
} = Astro.props;

const siteUrl = "https://justinashandler.com";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={siteUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={`${siteUrl}${ogImage}`}>

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`}>

  <script>
    // Unregister any legacy service workers (from old Squarespace mirror)
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.getRegistrations().then(regs => {
        regs.forEach(r => r.unregister());
      });
    }
  </script>

  <!-- Cloudflare Web Analytics — auto-injected by Cloudflare (no manual snippet needed) -->
</head>
<body>

  <nav class="nav">
    <a class="nav-logo" href="/">Justina Shandler</a>
    <ul class="nav-links">
      <li><a class={activePage === 'mess-is-medicine' ? 'active' : ''} href="/mess-is-medicine">Mess Is Medicine</a></li>
      <li><a class={activePage === 'about' ? 'active' : ''} href="/about">About</a></li>
      <li><a class={activePage === 'contact' ? 'active' : ''} href="/contact">Contact</a></li>
    </ul>
  </nav>

  <slot />

  <Footer />

</body>
</html>
