---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Creative Recess — Justina Shandler" activePage="creative-recess">

  <div style="padding: 40px 48px; max-width: 900px; margin: 0 auto;">

    <div class="cr-card">
      <div class="cr-glow"></div>

      <div>
        <span class="cr-tag cr-tag-orange">Creative Recess</span>
        <span style="font-size:1rem;margin:0 4px">&bull;</span>
        <span class="cr-tag cr-tag-green">Sept 26 to Oct 31</span>
      </div>

      <h1 class="cr-title">Make creativity fun again</h1>
      <p class="cr-subtitle">A 5-week play-based program for songwriters &amp; creatives.</p>
      <p class="cr-spots">Spots capped at 30.</p>
      <p class="cr-price">Play Pass: <strong>$200</strong></p>

      <a class="btn" href="https://buy.stripe.com/00weVee2T52DgYF2Ef3Je00" target="_blank" rel="noopener">Join now &mdash; $200</a>
    </div>

  </div>

  <div style="padding: 0 40px; max-width: 900px; margin: 0 auto;">
    <div class="cards-grid">

      <div class="card">
        <h3>What you get</h3>
        <ul>
          <li>Creative Recess Pregame: practices to get in the headspace and energy to create</li>
          <li>4 writing prompts per week: uniquely designed to return you to your childlike essence</li>
          <li>1 co-write per week: playtime is more fun with a playmate</li>
          <li>Weekly Zoom creation calls: see everyone and write in community</li>
          <li>Optional private group chat: idea swaps, artistic meltdowns, and support</li>
        </ul>
      </div>

      <div class="card">
        <h3>Secure your spot</h3>
        <p>Please friend <strong>Justina Shandler</strong> on Facebook after purchasing — you'll get your private invite to the group on September 25th.</p>
        <a class="btn" href="https://buy.stripe.com/00weVee2T52DgYF2Ef3Je00" target="_blank" rel="noopener">Pay $200 — Secure Checkout</a>
      </div>

    </div>

    <div class="testimonials">
      <h2>What past participants say</h2>

      <div class="testimonial">
        <blockquote>"I'm breaking through walls that have been there for years. I came into this challenge so casually, and now it's become life changing. Not because of what I'm doing, but because I'm doing."</blockquote>
        <cite>&mdash; Matt D, Former Creative Challenge participant</cite>
      </div>

      <div class="testimonial">
        <blockquote>"Best money I might have ever spent. The accountability, prompts, support, encouragement, feedback, collabs, and challenges made it fun."</blockquote>
        <cite>&mdash; Rachel M, Former Creative Challenge participant</cite>
      </div>

      <div class="testimonial">
        <blockquote>"I can't begin to tell you how empowering it was to participate, experience, witness, and share with this special group. It was one of the best things I ever did for myself. Take the leap."</blockquote>
        <cite>&mdash; Maria T, Former Creative Challenge participant</cite>
      </div>
    </div>

  </div>

</Layout>
