---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Mess Is Medicine — 30-Day Creative Challenge | Justina Shandler"
  activePage="mess-is-medicine"
  description="A 30-day creative challenge for writers, musicians & artists who keep saying 'I'll start tomorrow.' Daily prompts, live calls, community. $250. Starts March 22."
  ogImage="/images/mim-color.png"
>

  <div class="cr-wrap">

    <!-- ── HERO CARD ── -->
    <div class="cr-card">

      <!-- Asymmetric splatter blob — the actual card "shape" -->
      <svg class="cr-card-blob" viewBox="0 0 800 650" preserveAspectRatio="none" aria-hidden="true">
