            <stop offset="48%" stop-color="#1f4c32"/>
            <stop offset="100%" stop-color="#132d1e"/>
          </linearGradient>
          <!-- Paint roughness — displaces edge pixels to look like real brush paint -->
          <filter id="paintRough" x="-10%" y="-10%" width="120%" height="120%" color-interpolation-filters="sRGB">
            <feTurbulence type="fractalNoise" baseFrequency="0.035 0.025" numOctaves="4" seed="7" result="noise"/>
