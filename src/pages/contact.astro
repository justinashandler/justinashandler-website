---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Justina Shandler" activePage="contact">

  <div class="contact-layout">

    <div class="contact-photo-side">
      <img src="/images/mim-studio.jpg" alt="Justina laughing at the piano" class="contact-side-photo">
    </div>

    <div class="contact-form-side">
      <h1>Let's connect.</h1>
      <p class="intro">Due to the devastating reality that I am only one person in one body with one inbox and a deeply imperfect relationship to admin, I can't promise a speedy reply...but know I have spiritually received your message with immense intrigue.</p>

      <form action="https://formspree.io/f/xlgprkne" method="POST">
        <input type="hidden" name="_subject" value="New message from justinashandler.com">

        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required placeholder="Your name">
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="your@email.com">
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" required placeholder="Say whatever the heck it is you're saying..."></textarea>
        </div>

        <button type="submit" class="form-submit">Send it ✨</button>
      </form>
    </div>

  </div>

</Layout>
