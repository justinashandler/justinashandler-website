---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Justina Shandler" activePage="contact">

  <div class="contact-wrap">
    <h1>Let's connect!</h1>
    <p class="intro">Seeing as I am living in a human body with human limitations, it's possible I won't get a chance to reply to you, but trust that I see your message and am holding space for whatever the heck it is you're saying.</p>

    <form action="https://formspree.io/f/xlgprkne" method="POST">
      <input type="hidden" name="_subject" value="New message from justinashandler.com">

      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required placeholder="Your name">
      </div>

      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="your@email.com">
      </div>

      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" required placeholder="Say whatever the heck it is you're saying..."></textarea>
      </div>

      <button type="submit" class="form-submit">Send it ✨</button>
    </form>
  </div>

  <!-- ── STUDIO PHOTOS ── -->
  <div class="contact-photos-row">
    <img src="/images/mim-studio.jpg" alt="Justina laughing at the piano" class="contact-photo">
    <img src="/images/mim-studio-2.jpg" alt="Justina focused at the piano" class="contact-photo">
  </div>

  <!-- ── JUSTINA NATURE PHOTO ── -->
  <div class="contact-photo-block">
    <p class="contact-annotation">your ideas are legit great</p>
    <img src="/images/justina-nature.jpg" alt="Justina writing outdoors on a rock" class="contact-photo-feature">
  </div>

  <!-- ── FOOT PHOTO ── -->
  <div class="contact-photo-block contact-photo-block--foot">
    <img src="/images/foot.jpg" alt="Justina's feet in black sandals with blue toenails" class="contact-photo-feature contact-photo-foot">
    <p class="contact-annotation contact-annotation--slant">this is my fav pic of me. why fit in when you were born to stand out?</p>
  </div>

  <!-- ── GRANDMA PHOTO ── -->
  <div class="contact-photo-block contact-photo-block--grandma">
    <img src="/images/grandma-trash.jpg" alt="Grandma Sylvia standing in a trash can" class="contact-photo-feature contact-photo-grandma">
    <p class="contact-annotation contact-annotation--grandma">this is my grandma. as one of the classiest ladies, she still got in the trash sometimes. let's get messy like grandma sylvia.</p>
  </div>

</Layout>
